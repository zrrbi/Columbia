function renderKeywords(group='all') {
  const grid = document.getElementById('keywords-grid');
  const filtered = group === 'all' ? KW : KW.filter(k => k.g === group);
  grid.innerHTML = filtered.map((k, i) => {
    const uid = `cn_${k.g}_${i}`;
    return `<div class="keyword-card" data-group="${k.g}">
      <div class="kw-group-tag">Group ${k.g}</div>
      <div class="kw-title">${k.term}</div>
      <div class="kw-section-label">Who</div><div class="kw-text">${k.who}</div>
      <div class="kw-section-label">What</div><div class="kw-text">${k.what}</div>
      <div class="kw-section-label">Where</div><div class="kw-text">${k.where}</div>
      <div class="kw-section-label">When</div><div class="kw-text">${k.when}</div>
      <div class="kw-section-label">Significance</div><div class="kw-text">${k.sig}</div>
      <div class="cn-toggle" onclick="toggleCN('${uid}')">
        <span class="cn-arrow" id="arr_${uid}">▶</span>
        <span class="cn-toggle-label">中文翻译</span>
      </div>
      <div class="cn-block" id="${uid}">
        <div class="cn-label">主要人物</div><div class="cn-text">${k.cwho}</div>
        <div class="cn-label">内容</div><div class="cn-text">${k.cwhat}</div>
        <div class="cn-label">地点</div><div class="cn-text">${k.cwhere}</div>
        <div class="cn-label">时间</div><div class="cn-text">${k.cwhen}</div>
        <div class="cn-label">历史意义</div><div class="cn-text">${k.csig}</div>
      </div>
    </div>`;
  }).join('');
}

function toggleCN(uid) {
  document.getElementById(uid).classList.toggle('open');
  document.getElementById('arr_' + uid).classList.toggle('open');
}

function filterGroup(group, btn) {
  document.querySelectorAll('#panel-keywords .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderKeywords(group);
}

let cardStates = {}, currentIdx = 0, isFlipped = false, fcMode = 'all';
KW.forEach((_, i) => { cardStates[i] = 'unseen'; });

function getActiveDeck() {
  if (fcMode === 'review') return KW.map((_, i) => i).filter(i => cardStates[i] === 'review');
  if (fcMode === 'unseen') return KW.map((_, i) => i).filter(i => cardStates[i] === 'unseen');
  return KW.map((_, i) => i);
}

function renderFC() {
  const deck = getActiveDeck();
  if (!deck.length) {
    document.getElementById('fc-term').textContent = 'No cards in this deck!';
    document.getElementById('fc-back-content').innerHTML = '<div class="fc-back-title">Empty</div>';
    document.getElementById('fc-counter').textContent = '0 / 0';
    document.getElementById('fc-result-btns').style.display = 'none';
    return;
  }
  const k = KW[deck[currentIdx % deck.length]];
  document.getElementById('fc-term').textContent = k.term;
  document.getElementById('fc-back-content').innerHTML = `
    <div class="fc-back-title">${k.term}</div>
    <div class="fc-back-row"><strong>Who</strong>${k.who}</div>
    <div class="fc-back-row"><strong>What</strong>${k.what}</div>
    <div class="fc-back-row"><strong>Where</strong>${k.where}</div>
    <div class="fc-back-row"><strong>When</strong>${k.when}</div>
    <div class="fc-back-row"><strong>Significance</strong>${k.sig}</div>
    <hr class="fc-divider">
    <div class="fc-cn-row"><strong>主要人物</strong>${k.cwho}</div>
    <div class="fc-cn-row"><strong>内容</strong>${k.cwhat}</div>
    <div class="fc-cn-row"><strong>历史意义</strong>${k.csig}</div>`;
  const pos = (currentIdx % deck.length) + 1;
  document.getElementById('fc-counter').textContent = `${pos} / ${deck.length}`;
  document.getElementById('fc-progress').style.width = `${(pos/deck.length)*100}%`;
  document.getElementById('fc-result-btns').style.display = 'none';
  updateScore();
}

function flipCard() {
  isFlipped = !isFlipped;
  document.getElementById('fc-card').classList.toggle('flipped', isFlipped);
  if (isFlipped) document.getElementById('fc-result-btns').style.display = 'flex';
}

function markCard(status) {
  const deck = getActiveDeck();
  if (!deck.length) return;
  cardStates[deck[currentIdx % deck.length]] = status;
  updateScore(); fcNav(1);
}

function fcNav(dir) {
  const deck = getActiveDeck();
  if (!deck.length) return;
  currentIdx = (currentIdx + dir + deck.length) % deck.length;
  isFlipped = false;
  document.getElementById('fc-card').classList.remove('flipped');
  renderFC();
}

function shuffleDeck() {
  KW.sort(() => Math.random() - 0.5);
  currentIdx = 0; isFlipped = false;
  document.getElementById('fc-card').classList.remove('flipped');
  renderFC();
}

function resetDeck() {
  KW.forEach((_, i) => { cardStates[i] = 'unseen'; });
  currentIdx = 0; isFlipped = false;
  document.getElementById('fc-card').classList.remove('flipped');
  renderFC();
}

function updateScore() {
  document.getElementById('score-know').textContent = Object.values(cardStates).filter(s=>s==='know').length + ' know';
  document.getElementById('score-review').textContent = Object.values(cardStates).filter(s=>s==='review').length + ' review';
  document.getElementById('score-unseen').textContent = Object.values(cardStates).filter(s=>s==='unseen').length + ' unseen';
}

function fcFilter(mode, btn) {
  fcMode = mode;
  document.querySelectorAll('.fc-filter .filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentIdx = 0; isFlipped = false;
  document.getElementById('fc-card').classList.remove('flipped');
  renderFC();
}

function switchTab(tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelector(`[onclick="switchTab('${tab}')"]`).classList.add('active');
  document.getElementById('panel-' + tab).classList.add('active');
}

renderKeywords(); renderFC();
</script>
